# Required for Capacitor builds. This must be the HTTPS Vercel deployment that serves
# /api, /deepseek and /openai server-side proxies. Never put provider keys in this file.
VITE_API_BASE_URL=https://your-tavern-api.vercel.app

# Optional. Leave blank when the Vercel API domain already rewrites /collect and its APIs.
# VITE_COLLECT_BASE_URL=https://your-collection.vercel.app
# VITE_TAVERN_BASE_URL=https://your-tavern.vercel.app
VITE_ADVENTURE_CAMPAIGN=adventurex-2026

# Non-secret client settings.
VITE_LLM_MODEL=deepseek-v4-flash
VITE_OPENAI_PLANNING_MODEL=gpt-5
VITE_TRANSCRIBE_MODEL=gpt-4o-transcribe
VITE_IMAGE_MODEL=gpt-image-1
